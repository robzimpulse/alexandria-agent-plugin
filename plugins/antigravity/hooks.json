    "PreToolUse": [{ "matcher": "*", "hooks": [{ "command": "node /REPLACE/WITH/ABSOLUTE/PATH/dist/cli.cjs pre" }] }],
    "PostToolUse": [{ "matcher": "*", "hooks": [{ "command": "node /REPLACE/WITH/ABSOLUTE/PATH/dist/cli.cjs post" }] }],
